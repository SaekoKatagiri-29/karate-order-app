generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// 対戦大学
model Team {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   // "NATIONAL"(国立) | "PUBLIC"(公立)
  coaches   Coach[]
  players   Player[]
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 監督
model Coach {
  id        Int      @id @default(autoincrement())
  name      String
  nickname  String?
  startYear Int
  endYear   Int?
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 相手チームの選手
model Player {
  id             Int           @id @default(autoincrement())
  name           String
  nickname       String?
  enrollmentYear Int
  isRetired      Boolean       @default(false)
  teamId         Int
  team           Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  orderEntries   OrderEntry[]
  matchResults   MatchResult[] @relation("OpponentPlayerResults")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// 阪大選手
model OsakaPlayer {
  id             Int           @id @default(autoincrement())
  name           String
  enrollmentYear Int
  isRetired      Boolean       @default(false)
  matchResults   MatchResult[] @relation("OsakaPlayerResults")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// 試合
model Match {
  id                Int           @id @default(autoincrement())
  date              DateTime
  teamId            Int
  team              Team          @relation(fields: [teamId], references: [id])
  coachId           Int?
  coach             Coach?        @relation(fields: [coachId], references: [id])
  matchType         String        // "OFFICIAL"(公式戦) | "PRACTICE"(練習試合)
  isTournamentFirst Boolean       @default(false)
  result            String?       // "WIN" | "LOSS" | "DRAW"
  notes             String?
  orderEntries      OrderEntry[]
  matchResults      MatchResult[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// オーダー（先鋒・中堅・大将）
model OrderEntry {
  id       Int    @id @default(autoincrement())
  matchId  Int
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  position String // "SENPO" | "CHUKEN" | "TAISHO"
  playerId Int
  player   Player @relation(fields: [playerId], references: [id])
}

// 個人戦結果
model MatchResult {
  id               Int          @id @default(autoincrement())
  matchId          Int
  match            Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  position         String?      // "SENPO" | "CHUKEN" | "TAISHO" | null(練習試合の個人対決)
  osakPlayerId     Int?
  osakaPlayer      OsakaPlayer? @relation("OsakaPlayerResults", fields: [osakPlayerId], references: [id])
  opponentPlayerId Int?
  opponentPlayer   Player?      @relation("OpponentPlayerResults", fields: [opponentPlayerId], references: [id])
  result           String       // "WIN" | "LOSS" | "DRAW"
  score            String?
  notes            String?
}
